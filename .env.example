# ── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRY=7d

# First-run only: used to set the admin password on /api/v1/auth/setup
# Remove from .env after first login
SETUP_TOKEN=change-me-before-first-login

# ── Database ─────────────────────────────────────────────────────────────────
# Development: local PostgreSQL (e.g. docker run -e POSTGRES_PASSWORD=... -p 5432:5432 postgres:17-alpine)
# Production (VPS): postgresql://postgres:<password>@postgres:5432/petstay_prod
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/petstay_dev

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Storage ──────────────────────────────────────────────────────────────────
# Uploads stored at DATA_DIR/uploads inside the container (volume-mounted on VPS)
DATA_DIR=./data

# ── Frontend (baked into Vite bundle at build time) ──────────────────────────
# Production: set to https://petstay.aranciatech.com.br/api/v1
# Development: leave empty (Vite proxy handles /api → localhost:3002)
# VITE_API_URL=
